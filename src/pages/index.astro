---
// SSG — fully prerendered, no server runtime needed
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Menú AR</title>

    <!-- Vendor scripts from jsDelivr CDN — loaded before body, is:inline skips Astro bundling -->
    <script src="https://cdn.jsdelivr.net/npm/aframe@1.7.1/dist/aframe-v1.7.1.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/mind-ar@1.2.5/dist/mindar-image-aframe.prod.js" is:inline></script>
  </head>

  <body>
    <!-- ── Permission gate (visible by default) ──────────────────────────── -->
    <div id="permission-gate" class="gate" aria-live="polite">
      <div class="gate__card">
        <div class="gate__icon" aria-hidden="true">🍔</div>
        <h1 class="gate__title">Menú AR</h1>
        <p id="gate-message" class="gate__message">
          Por favor, concede permisos de cámara para ver el menú en AR
        </p>
        <button id="start-ar-btn" class="gate__btn" type="button">
          Iniciar experiencia AR para ver el menú
        </button>
      </div>
    </div>

    <!-- ── AR container ───────────────────────────────────────────────────── -->
    <!-- NOT hidden — gate overlay sits above it (z-index:100).              -->
    <!-- <a-scene> needs to init with real dimensions; hidden=0×0 breaks it. -->
    <div id="ar-container" class="ar-container">
      <a-scene
        mindar-image="imageTargetSrc: /assets/targets.mind; autoStart: false; uiLoading: no; uiError: no; uiScanning: no"
        color-space="sRGB"
        renderer="colorManagement: true"
        vr-mode-ui="enabled: false"
        device-orientation-permission-ui="enabled: false"
      >
        <a-assets>
          <a-asset-item
            id="hamburguesa"
            src="/assets/hamburguesa_maracucha.glb"
          ></a-asset-item>
        </a-assets>

        <a-camera position="0 0 0" look-controls="enabled: false"></a-camera>

        <a-entity mindar-image-target="targetIndex: 0">
          <a-gltf-model
            src="#hamburguesa"
            position="0 0 0.3"
            rotation="90 0 0"
            scale="0.5 0.5 0.5"
            animation-mixer
          ></a-gltf-model>
        </a-entity>
      </a-scene>

      <!-- Scanning overlay shown while tracking ─────────────────────────── -->
      <div id="scan-overlay" class="scan-overlay">
        <div class="scan-overlay__frame"></div>
        <p class="scan-overlay__hint">Apunta al menú para ver tu plato en 3D</p>
      </div>
    </div>
  </body>
</html>

<style>
  /* ── Reset & base ─────────────────────────────────────────────────────── */
  :root {
    --color-bg: #0a0a0a;
    --color-surface: #1a1a1a;
    --color-border: rgba(255, 255, 255, 0.12);
    --color-text: #f5f5f5;
    --color-muted: rgba(255, 255, 255, 0.55);
    --color-accent: #ff6b35;
    --color-accent-hover: #ff8557;
    --radius-card: 1.25rem;
    --radius-btn: 0.75rem;
    --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.6);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    width: 100%;
    height: 100%;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow: hidden;
  }

  /* ── Permission gate ──────────────────────────────────────────────────── */
  .gate[hidden] { display: none; }

  .gate {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: var(--color-bg);
    z-index: 100;
  }

  .gate__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 26rem;
    padding: 2rem 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    text-align: center;
  }

  .gate__icon {
    font-size: clamp(3rem, 10vw, 4.5rem);
    line-height: 1;
  }

  .gate__title {
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .gate__message {
    font-size: clamp(0.875rem, 3vw, 1rem);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .gate__btn {
    width: 100%;
    min-height: 3rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: #fff;
    font-size: clamp(0.875rem, 3vw, 1rem);
    font-weight: 600;
    border: none;
    border-radius: var(--radius-btn);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.1s ease;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .gate__btn:hover {
    background: var(--color-accent-hover);
  }

  .gate__btn:active {
    transform: scale(0.97);
  }

  /* Error state */
  .gate--error .gate__btn {
    background: #555;
    cursor: not-allowed;
  }

  /* ── AR container ─────────────────────────────────────────────────────── */
  .ar-container {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
  }

  .ar-container a-scene {
    width: 100%;
    height: 100%;
  }

  /* ── Scan overlay ─────────────────────────────────────────────────────── */
  .scan-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    pointer-events: none;
    z-index: 10;
  }

  .scan-overlay__frame {
    width: clamp(10rem, 60vw, 16rem);
    aspect-ratio: 1;
    border: 2px solid var(--color-accent);
    border-radius: 1rem;
    box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.35);
    animation: pulse 2s ease-in-out infinite;
  }

  .scan-overlay__hint {
    font-size: clamp(0.8rem, 3vw, 0.9rem);
    color: #fff;
    background: rgba(0, 0, 0, 0.55);
    padding: 0.4rem 0.9rem;
    border-radius: 2rem;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* Hide scan overlay while target is tracked ────────────────────────── */
  .scan-overlay--hidden {
    display: none;
  }
</style>

<script>
  // All DOM interaction and AR logic runs client-side only.
  // MindAR + A-Frame are loaded as global scripts via <script is:inline> in <head>.

  const gate        = document.getElementById('permission-gate') as HTMLDivElement;
  const gateMessage = document.getElementById('gate-message') as HTMLParagraphElement;
  const startBtn    = document.getElementById('start-ar-btn') as HTMLButtonElement;
  const arContainer = document.getElementById('ar-container') as HTMLDivElement;
  const scanOverlay = document.getElementById('scan-overlay') as HTMLDivElement;

  startBtn.addEventListener('click', async () => {
    startBtn.disabled = true;
    startBtn.textContent = 'Iniciando…';
    console.log('[AR] button clicked');

    try {
      console.log('[AR] requesting camera...');
      await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
      console.log('[AR] camera granted');

      gate.setAttribute('hidden', '');
      console.log('[AR] gate hidden');

      const scene = arContainer.querySelector('a-scene') as HTMLElement & {
        hasLoaded?: boolean;
        systems?: Record<string, { start?: () => void; stop?: () => void }>;
      };

      console.log('[AR] scene element:', scene);
      console.log('[AR] scene.hasLoaded:', scene?.hasLoaded);
      console.log('[AR] scene.systems keys:', scene?.systems ? Object.keys(scene.systems) : 'none');

      const startMindAR = (): void => {
        const sys = scene.systems?.['mindar-image-system'];
        console.log('[AR] mindar-image-system:', sys);
        if (sys?.start) {
          console.log('[AR] calling start()...');
          sys.start();
          console.log('[AR] start() called');
        } else {
          console.error('[AR] mindar-image-system or start() not found');
        }
      };

      if (scene.hasLoaded) {
        console.log('[AR] scene already loaded — starting immediately');
        startMindAR();
      } else {
        console.log('[AR] scene not loaded yet — waiting for loaded event');
        scene.addEventListener('loaded', () => {
          console.log('[AR] loaded event fired');
          startMindAR();
        }, { once: true });
      }

      const target = arContainer.querySelector('[mindar-image-target]');
      target?.addEventListener('targetFound', () => {
        console.log('[AR] target found');
        scanOverlay.classList.add('scan-overlay--hidden');
      });
      target?.addEventListener('targetLost', () => {
        console.log('[AR] target lost');
        scanOverlay.classList.remove('scan-overlay--hidden');
      });

    } catch (err) {
      console.error('[AR] error:', err);
      gate.classList.add('gate--error');
      gateMessage.textContent =
        'No se pudieron obtener los permisos de cámara. Por favor, revisa la configuración de tu navegador.';
      startBtn.textContent = 'Permisos denegados';
    }
  });
</script>
